# ─────────────────────────────────────────────────────────────
# Circadian Intelligence Platform — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#
# cp .env.example .env
# ─────────────────────────────────────────────────────────────


# ── Junction / Vital API ──────────────────────────────────────
# Get API key from: https://app.junction.com → Team Config → API Keys
# For sandbox (development): use https://api.sandbox.eu.junction.com
# For production (real users): use https://api.eu.junction.com

VITAL_BASE_URL=https://api.sandbox.eu.junction.com
VITAL_API_KEY=junction_api_key_here


# ── OpenWeather API ───────────────────────────────────────────
# Used for environmental context (UV index, sunrise, sunset, cloud cover)
# Get a free key at: https://openweathermap.org/api

OPENWEATHER_API_KEY=openweather_api_key_here


# ── Supabase ──────────────────────────────────────────────────
# Your Supabase project URL and publishable key
# Found at: https://app.supabase.com → Project Settings → API

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_publishable_key_here


# ── Frontend URL (for CORS) ───────────────────────────────────
# Set this to the domain where the Nuxt frontend is hosted
# Example: https://looportchestra.com or http://localhost:3000

FRONTEND_URL=http://localhost:3000
